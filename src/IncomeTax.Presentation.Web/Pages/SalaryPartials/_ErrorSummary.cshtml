@model Salary

@if (Model.ErrorAmount || Model.ErrorFrequency)
{
    <div class="govuk-error-summary" data-testid="salary__error-summary__error" data-module="govuk-error-summary">
        <div role="alert">
            <h2 class="govuk-error-summary__title">
                There is a problem
            </h2>
            @if (Model.ErrorAmount)
            {
                <div class="govuk-error-summary__body">
                    <ul class="govuk-list govuk-error-summary__list">
                        <li>
                            <a href="#salary__text-input__amount" data-testid="salary__error-summary__error__amount">Enter the amount you are paid</a>
                        </li>
                    </ul>
                </div>
            }
            @if (Model.ErrorFrequency)
            {
                <div class="govuk-error-summary__body">
                    <ul class="govuk-list govuk-error-summary__list">
                        <li>
                            <a href="#salary__radio-set__frequency_@Model.Options[0]" data-testid="salary__error-summary__error__frequency">Select how often you are paid this amount</a>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </div>
}