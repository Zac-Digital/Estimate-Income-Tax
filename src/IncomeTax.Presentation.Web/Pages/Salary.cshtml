@page "/salary"
@model IncomeTax.Presentation.Web.Pages.Salary
@{
    ViewData["Title"] = "Salary";
}

<form method="post">
    @await Html.PartialAsync("SalaryPartials/_ErrorSummary", Model)

    <h2 class="govuk-heading-l">How much are you paid?</h2>
    
    @await Html.PartialAsync("SalaryPartials/_TextInput", Model)
    @await Html.PartialAsync("SalaryPartials/_RadioSet", Model)

    <div class="govuk-button-group">
        <button type="submit" class="govuk-button" data-module="govuk-button">
            Continue
        </button>
    </div>
</form>