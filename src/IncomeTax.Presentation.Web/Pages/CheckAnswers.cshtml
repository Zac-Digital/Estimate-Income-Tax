@page "/check-answers"
@model IncomeTax.Presentation.Web.Pages.CheckAnswers

@{
    ViewData["Title"] = "Check Your Answers";
}

<h1 class="govuk-heading-xl">Check your answers</h1>

<h2 class="govuk-heading-l">Your Income</h2>

<form method="post">
    <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Gross income
            </dt>
            <dd class="govuk-summary-list__value">
                @Model.GrossIncome
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" asp-page="@nameof(Salary)">Change<span class="govuk-visually-hidden"> Gross income</span></a>
            </dd>
        </div>
        
        @if (Model.DaysWorkedPerWeek is not null)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Days worked a week
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.DaysWorkedPerWeek
                </dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" asp-page="@nameof(HowManyDaysWorked)">Change<span class="govuk-visually-hidden"> Days worked a week</span></a>
                </dd>
            </div>
        }
        
        @if (Model.HoursWorkedPerWeek is not null)
        {
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">
                    Hours worked a week
                </dt>
                <dd class="govuk-summary-list__value">
                    @Model.HoursWorkedPerWeek
                </dd>
                <dd class="govuk-summary-list__actions">
                    <a class="govuk-link" asp-page="@nameof(HowManyHoursWorked)">Change<span class="govuk-visually-hidden"> Hours worked a week</span></a>
                </dd>
            </div>
        }
        
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Over State Pension age
            </dt>
            <dd class="govuk-summary-list__value">
                @Model.OverStatePensionAge
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" asp-page="@nameof(StatePension)">Change<span class="govuk-visually-hidden"> Over State Pension age</span></a>
            </dd>
        </div>
    </dl>
    
    <h2 class="govuk-heading-l">Additional questions (Optional)</h2>
    <p class="govuk-body">Your results may be more accurate if you answer additional questions.</p>
    
    <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Tax Code
            </dt>
            <dd class="govuk-summary-list__value">
                @CheckAnswers.TaxCode
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="#">Change<span class="govuk-visually-hidden"> Tax Code</span></a>
            </dd>
        </div>
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Scottish Income Tax
            </dt>
            <dd class="govuk-summary-list__value">
                @(Model.ScottishIncomeTax ?? "Not provided")
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="#">Add<span class="govuk-visually-hidden"> Scottish Income Tax</span></a>
            </dd>
        </div>
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Pension contributions
            </dt>
            <dd class="govuk-summary-list__value">
                @(Model.PensionContributions ?? "Not provided")
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="#">Add<span class="govuk-visually-hidden"> Pension contributions</span></a>
            </dd>
        </div>
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Student loan
            </dt>
            <dd class="govuk-summary-list__value">
                @(Model.StudentLoan ?? "Not provided")
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="#">Add<span class="govuk-visually-hidden"> Student loan</span></a>
            </dd>
        </div>
        <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">
                Postgraduate loan
            </dt>
            <dd class="govuk-summary-list__value">
                @(Model.PostgraduateLoan ?? "Not provided")
            </dd>
            <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="#">Add<span class="govuk-visually-hidden"> Postgraduate loan</span></a>
            </dd>
        </div>
    </dl>
    
    <button type="submit" class="govuk-button" data-module="govuk-button" data-testid="button">
        Calculate take-home pay
    </button>
</form>